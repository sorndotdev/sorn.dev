---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  prose?: boolean;
}

const { title, description, prose } = Astro.props;
const ogImage = `https://sorn.dev/images/og-default.png`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} — Sorn.dev</title>
    {description && <meta name="description" content={description} />}
    <meta property="og:title" content={`${title} — Sorn.dev`} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://sorn.dev" />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Sorn Maksumic",
      "givenName": "Sorn",
      "familyName": "Maksumic",
      "jobTitle": "Fintech Software Engineer",
      "description": "Building high-quality software at the intersection of finance and technology. Java, distributed systems, and domain-driven design.",
      "url": "https://www.sorn.dev",
      "email": "maksumic@protonmail.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Dubai",
        "addressCountry": "United Arab Emirates"
      },
      "sameAs": [
        "https://github.com/sorndotdev",
        "https://linkedin.com/in/sorndotdev"
      ],
      "knowsAbout": [
        "Java",
        "JVM",
        "Distributed Systems",
        "TDD",
        "DDD",
        "CQRS",
        "Event Sourcing",
        "Kafka",
        "RabbitMQ",
        "PostgreSQL",
        "Foreign Exchange",
        "Multi-Currency Ledgers",
        "Dividend Investing",
        "Microservices",
        "Kubernetes",
        "GCP",
        "REST API Design",
        "Fintech",
        "Accounting",
        "Fundamental Analysis",
        "Scrum"
      ],
      "alumniOf": {
        "@type": "CollegeOrUniversity",
        "name": "University of South Eastern Norway",
        "sameAs": "https://www.usn.no"
      },
      "award": "Best Bachelor Project 2021",
      "hasCredential": {
        "@type": "EducationalOccupationalCredential",
        "name": "Professional Scrum Master I",
        "url": "https://www.credly.com/badges/acdabbf8-9bed-44b6-89c1-eb93bf718c47/public_url",
        "issuedBy": {
          "@type": "Organization",
          "name": "Scrum.org"
        }
      },
      "worksFor": [
        {
          "@type": "Organization",
          "name": "Revolut",
          "description": "Software Engineer, Wealth & Trading Team",
          "location": "Dubai, United Arab Emirates"
        },
        {
          "@type": "Organization",
          "name": "Adyen",
          "description": "Team Lead, Foreign Exchange Team",
          "location": "Amsterdam, Netherlands"
        },
        {
          "@type": "Organization",
          "name": "Snapstock",
          "description": "Founding Engineer — Dividend stock analysis platform"
        }
      ]
    }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-navy-950 text-slate-300 antialiased min-h-screen flex flex-col">
    <!-- Nav -->
    <header class="sticky top-0 z-50 border-b border-navy-700/30 bg-navy-950/80 backdrop-blur-xl">
      <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 group">
          <span class="text-lg font-bold gradient-text group-hover:opacity-80 transition-opacity">Sorn.dev</span>
          <span class="hidden sm:inline text-sm text-slate-600">Software Engineer. Building Quality Software.</span>
        </a>
        <div class="flex items-center gap-4 sm:gap-8 text-xs sm:text-sm">
          <a href="/" class="text-slate-400 hover:text-white transition-colors whitespace-nowrap">Home</a>
          <a href="/about" class="text-slate-400 hover:text-white transition-colors whitespace-nowrap">About</a>
          <a href="/case-studies" class="text-slate-400 hover:text-white transition-colors whitespace-nowrap">Case Studies</a>
          <a href="/open-source" class="text-slate-400 hover:text-white transition-colors whitespace-nowrap">Open Source</a>
        </div>
      </nav>
    </header>

    <!-- Main -->
    <main class="flex-1">
      <div class={prose ? "prose-custom max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12" : ""}>
        <slot />
      </div>
    </main>

    <!-- Footer -->
    <footer class="border-t border-navy-700/30">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between text-sm text-slate-600">
        <span>&copy; 2026 Sorn Maksumic</span>
        <div class="flex items-center gap-5">
          <a href="https://github.com/sorndotdev" target="_blank" rel="noopener noreferrer" class="hover:text-slate-300 transition-colors" aria-label="GitHub">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
          <a href="https://linkedin.com/in/sorndotdev" target="_blank" rel="noopener noreferrer" class="hover:text-slate-300 transition-colors" aria-label="LinkedIn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  .prose-custom h1, .prose-custom h2, .prose-custom h3 {
    color: #f1f5f9;
  }
  .prose-custom h1 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }
  .prose-custom h2 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-custom h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .prose-custom p, .prose-custom li {
    color: #94a3b8;
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .prose-custom a {
    color: #818cf8;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose-custom a:hover {
    color: #a78bfa;
  }
  .prose-custom code {
    color: #34d399;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875em;
  }
  .prose-custom pre {
    background: #1a2332;
    border: 1px solid #253044;
    border-radius: 0.75rem;
    padding: 1.25rem;
    overflow-x: auto;
  }
  .prose-custom pre code {
    color: #e2e8f0;
    font-size: 0.8125rem;
  }
  .prose-custom blockquote {
    border-left: 3px solid #6366f1;
    padding-left: 1.25rem;
    color: #64748b;
    font-style: italic;
    margin: 1.5rem 0;
  }
  .prose-custom img {
    border-radius: 0.75rem;
    border: 1px solid #253044;
    max-width: 100%;
    height: auto;
  }
  .prose-custom hr {
    border-color: #253044;
    margin: 2rem 0;
  }
  .prose-custom table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }
  .prose-custom th {
    color: #f1f5f9;
    font-weight: 600;
    text-align: left;
    padding: 0.75rem;
    border-bottom: 1px solid #253044;
  }
  .prose-custom td {
    padding: 0.75rem;
    border-bottom: 1px solid #1a2332;
  }
</style>
