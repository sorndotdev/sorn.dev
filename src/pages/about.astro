---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="About Sorn Maksumic — fintech software engineer at Revolut and Adyen. Java, distributed systems, domain-driven design.">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">About</h1>
    <p class="text-slate-500 mb-10">Software engineer building quality software in fintech.</p>

    <!-- Bio card -->
    <section class="mb-16">
      <div class="glass-card rounded-2xl p-6 sm:p-8">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-4">
          <div>
            <h2 class="text-xl font-semibold text-white">Sorn Maksumic</h2>
            <p class="text-slate-400">Dubai, United Arab Emirates</p>
          </div>
          <div class="flex gap-4">
            <a href="https://github.com/sorndotdev" target="_blank" rel="noopener noreferrer" class="text-slate-500 hover:text-indigo-400 transition-colors text-sm font-medium">
              GitHub ↗
            </a>
            <a href="https://linkedin.com/in/sornm" target="_blank" rel="noopener noreferrer" class="text-slate-500 hover:text-indigo-400 transition-colors text-sm font-medium">
              LinkedIn ↗
            </a>
          </div>
        </div>
        <p class="text-slate-400 leading-relaxed">
          Java fintech engineer with experience at some of the world's leading fintech companies.
          Focused on high-quality software, domain-driven design, and building systems that scale.
        </p>
      </div>
    </section>

    <!-- Experience -->
    <section class="mb-16">
      <h2 class="text-xs font-semibold text-slate-600 uppercase tracking-[0.2em] mb-6">Professional Experience</h2>
      <div class="space-y-4">
        <!-- Revolut -->
        <div class="glass-card rounded-xl p-5 sm:p-6">
          <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-3 mb-3">
            <div class="flex items-center gap-3">
              <img src="/images/revolut-logo.svg" alt="Revolut" class="h-5 opacity-60 shrink-0" />
              <div>
                <h3 class="text-white font-semibold">Revolut</h3>
                <p class="text-slate-400 text-sm">Software Engineer, Wealth & Trading Team</p>
              </div>
            </div>
            <span class="text-xs text-slate-600 whitespace-nowrap">Jul 2025 — Present</span>
          </div>
          <p class="text-slate-500 text-sm mb-3">Dubai, United Arab Emirates</p>
          <div class="flex flex-wrap gap-1.5">
            {["Java", "JVM", "Mockito", "JUnit", "Spock", "Gradle", "Groovy", "RDBMS", "PostgreSQL", "JOOQ", "Flyway", "Redis", "GCP", "Cloud SQL", "Microservices", "Kubernetes", "Grafana", "Prometheus", "NewRelic", "CQRS", "Kafka", "RabbitMQ", "TDD", "DDD", "Event Sourcing", "LLM Integration"].map(s => <span class="px-2 py-0.5 bg-navy-800/30 border border-navy-700/30 text-slate-500 text-xs rounded">{s}</span>)}
          </div>
        </div>

        <!-- Adyen Team Lead -->
        <div class="glass-card rounded-xl p-5 sm:p-6">
          <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-3 mb-3">
            <div class="flex items-center gap-3">
              <img src="/images/adyen-logo.svg" alt="Adyen" class="h-5 opacity-60 shrink-0" />
              <div>
                <h3 class="text-white font-semibold">Adyen <span class="text-xs text-emerald-500 font-normal">(Promoted)</span></h3>
                <p class="text-slate-400 text-sm">Team Lead, Foreign Exchange Team</p>
              </div>
            </div>
            <span class="text-xs text-slate-600 whitespace-nowrap">Aug 2023 — Jul 2025</span>
          </div>
          <p class="text-slate-500 text-sm mb-3">Amsterdam, The Netherlands</p>
          <p class="text-slate-500 text-sm leading-relaxed">
            Led a team of 4 engineers building Adyen's foreign exchange infrastructure — 
            multi-currency bookkeeping, FX rates, and immutable double-entry ledger systems 
            for global payment processing.
          </p>
          <div class="mt-3">
            <a href="https://www.credly.com/badges/acdabbf8-9bed-44b6-89c1-eb93bf718c47/public_url" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-xs text-slate-500 hover:text-indigo-400 transition-colors">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 15l-2 5 2-1 2 1-2-5z"/><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/></svg>
              Professional Scrum Master (PSM I) — Scrum.org
            </a>
          </div>
        </div>

        <!-- Adyen SE -->
        <div class="glass-card rounded-xl p-5 sm:p-6">
          <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-3 mb-3">
            <div class="flex items-center gap-3">
              <img src="/images/adyen-logo.svg" alt="Adyen" class="h-5 opacity-60 shrink-0" />
              <div>
                <h3 class="text-white font-semibold">Adyen</h3>
                <p class="text-slate-400 text-sm">Software Engineer</p>
              </div>
            </div>
            <span class="text-xs text-slate-600 whitespace-nowrap">Aug 2021 — Jul 2023</span>
          </div>
          <p class="text-slate-500 text-sm mb-3">Amsterdam, The Netherlands</p>
          <div class="flex flex-wrap gap-1.5">
            {["Java", "JVM", "Mockito", "JUnit", "Gradle", "Groovy", "RDBMS", "PostgreSQL", "MyBatis", "OGNL", "Kafka", "RabbitMQ", "Event Sourcing", "Message Store", "Event Store"].map(s => <span class="px-2 py-0.5 bg-navy-800/30 border border-navy-700/30 text-slate-500 text-xs rounded">{s}</span>)}
          </div>
        </div>
      </div>
    </section>

    <!-- Education -->
    <section class="mb-16">
      <h2 class="text-xs font-semibold text-slate-600 uppercase tracking-[0.2em] mb-6">Education</h2>
      <div class="glass-card rounded-xl p-5 sm:p-6">
        <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-3 mb-2">
          <div>
            <h3 class="text-white font-semibold">University of South Eastern Norway</h3>
            <p class="text-slate-400 text-sm">Bachelor's degree, Computer Science</p>
          </div>
          <span class="text-xs text-slate-600 whitespace-nowrap">2018 — 2021</span>
        </div>
        <p class="text-slate-500 text-sm">Kongsberg, Norway · Won Best Bachelor Project 2021</p>
      </div>
    </section>

    <!-- Credentials -->
    <section>
      <h2 class="text-xs font-semibold text-slate-600 uppercase tracking-[0.2em] mb-6">Credentials</h2>
      <div class="flex flex-wrap gap-3">
        <a href="https://www.credly.com/badges/acdabbf8-9bed-44b6-89c1-eb93bf718c47/public_url" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 py-2 glass-card rounded-lg text-sm text-slate-400 hover:text-white transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 15l-2 5 2-1 2 1-2-5z"/><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/></svg>
          Professional Scrum Master (PSM I)
        </a>
        <a href="https://kongsbergdigital.com/news/students-won-award-in-collaboration-with-kongsberg-digital" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 py-2 glass-card rounded-lg text-sm text-slate-400 hover:text-white transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          Best Bachelor Project 2021
        </a>
      </div>
    </section>
  </div>
</BaseLayout>
