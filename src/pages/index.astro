---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Sorn Maksumic — Fintech Software Engineer" description="Sorn's personal website about high-quality software engineering. Java fintech engineer. Adyen, Revolut, Snapstock.">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
    <!-- Hero -->
    <div class="mb-24">
      <div class="flex flex-col lg:flex-row lg:items-start justify-between gap-12">
        <div class="max-w-2xl">
          <div class="inline-flex items-center gap-2 px-3 py-1 bg-navy-800/50 border border-navy-700/50 rounded-full text-slate-400 text-xs font-medium mb-8">
            <span class="w-1.5 h-1.5 bg-red-500 rounded-full animate-pulse glow-dot"></span>
            Engineering @ Revolut
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-[1.1] tracking-tight mb-4">
            Sorn <span class="gradient-text">Maksumic</span>
          </h1>
          <p class="text-xl sm:text-2xl text-slate-400 font-medium mb-3">
            Fintech Software Engineer
          </p>
          <p class="text-slate-500 text-lg mb-6 max-w-xl leading-relaxed">
            Building high-quality software at the intersection of finance and technology.
            Java, distributed systems, and domain-driven design.
          </p>
          <div class="flex items-center gap-4 mb-10">
            <span class="text-xs text-slate-600 uppercase tracking-wider">Previously at</span>
            <img src="/images/adyen-logo.svg" alt="Adyen" class="h-5 opacity-40 hover:opacity-70 transition-opacity" />
            <img src="/images/revolut-logo.svg" alt="Revolut" class="h-5 opacity-40 hover:opacity-70 transition-opacity" />
          </div>
          <div class="flex flex-wrap gap-3">
            <a href="/about" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium transition-all bg-blue-600 hover:bg-blue-500 text-white shadow-lg shadow-blue-600/20">
              About me
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="/case-studies" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium transition-all glass-card text-slate-300 hover:text-white">
              Case Studies
            </a>
            <a href="/open-source" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium transition-all glass-card text-slate-300 hover:text-white">
              Open Source
            </a>
          </div>
        </div>
        <div class="hidden lg:block shrink-0">
          <!-- Terminal card -->
          <div class="glass-card rounded-2xl p-5 w-72">
            <div class="flex items-center gap-1.5 mb-4 pb-4 border-b border-navy-700/50">
              <span class="w-3 h-3 rounded-full bg-red-500/80"></span>
              <span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
              <span class="w-3 h-3 rounded-full bg-emerald-500/80"></span>
              <span class="text-xs text-slate-600 ml-2 font-mono">sorn@dev</span>
            </div>
            <div class="font-mono text-xs space-y-2">
              <div><span class="text-emerald-400">$</span> <span class="text-white">cat</span> <span class="text-slate-500">credentials.txt</span></div>
              <div><span class="text-blue-400">Adyen</span> <span class="text-slate-600">—</span> <span class="text-slate-400">Team Lead, FX</span></div>
              <div><span class="text-blue-400">Revolut</span> <span class="text-slate-600">—</span> <span class="text-slate-400">Wealth & Trading</span></div>
              <div><span class="text-blue-400">Snapstock</span> <span class="text-slate-600">—</span> <span class="text-slate-400">Founding Engineer</span></div>
              <div><span class="text-slate-600">PSM I</span> <span class="text-slate-600">—</span> <span class="text-slate-400">Scrum Master</span></div>
              <div class="pt-2 border-t border-navy-700/50 mt-2"><span class="text-emerald-400">$</span> <span class="text-white animate-pulse">▌</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-24">
      <div class="glass-card rounded-xl p-6 text-center sm:text-left">
        <div class="text-3xl font-bold gradient-text mb-1">5+</div>
        <div class="text-sm text-slate-500">Years in Fintech Engineering</div>
      </div>
      <div class="glass-card rounded-xl p-6 text-center sm:text-left">
        <div class="text-3xl font-bold gradient-text mb-1">2</div>
        <div class="text-sm text-slate-500">Fintech Companies</div>
      </div>
      <div class="glass-card rounded-xl p-6 text-center sm:text-left">
        <div class="text-3xl font-bold gradient-text mb-1">1,800+</div>
        <div class="text-sm text-slate-500">Dividend Investors Served</div>
      </div>
    </div>

    <!-- Featured -->
    <div class="mb-24">
      <h2 class="text-xs font-semibold text-slate-600 uppercase tracking-[0.2em] mb-6">Featured</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <a href="/case-studies" class="glass-card rounded-xl p-6 group transition-all">
          <div class="flex items-center gap-2 text-indigo-400 text-xs font-semibold uppercase tracking-wider mb-3">
            <span class="w-1.5 h-1.5 bg-indigo-500 rounded-full"></span>
            Case Study
          </div>
          <h3 class="text-lg font-semibold text-white group-hover:text-indigo-400 transition-colors mb-2">Snapstock.app</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Dividend stock analysis platform built with Ryne Williams. 1,800+ active investors discovering clearer investment decisions.</p>
        </a>
        <a href="/open-source" class="glass-card rounded-xl p-6 group transition-all">
          <div class="flex items-center gap-2 text-emerald-400 text-xs font-semibold uppercase tracking-wider mb-3">
            <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full"></span>
            Open Source
          </div>
          <h3 class="text-lg font-semibold text-white group-hover:text-emerald-400 transition-colors mb-2">fmp4j</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Lightweight Java SDK for Financial Modeling Prep API. Type-safe interface for stock market data and financial statements.</p>
        </a>
      </div>
    </div>

    <!-- Domain Expertise -->
    <div>
      <h2 class="text-xs font-semibold text-slate-600 uppercase tracking-[0.2em] mb-6">Domain Expertise</h2>
      <div class="flex flex-wrap gap-2">
        {["Java", "JVM", "Distributed Systems", "TDD", "DDD", "CQRS", "Event Sourcing", "Kafka", "PostgreSQL", "Foreign Exchange", "Multi-Currency Ledgers", "Dividend Investing", "Microservices", "Kubernetes", "GCP"].map((skill) => (
          <span class="px-3 py-1.5 bg-navy-800/30 border border-navy-700/30 text-slate-500 text-xs font-medium rounded-lg hover:border-indigo-500/30 hover:text-slate-300 transition-colors">{skill}</span>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
